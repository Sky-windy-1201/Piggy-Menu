rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    match /menuItems/{dishId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
